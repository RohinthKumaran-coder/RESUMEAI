generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  analyses  Analysis[]
}

model Analysis {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole     String
  resumeFileName String
  resumeText     String   @db.Text

  // Extracted profile
  candidateName   String?
  candidateEmail  String?
  candidatePhone  String?
  education       Json?    @default("[]")
  experience      Json?    @default("[]")
  projects        Json?    @default("[]")
  certifications  Json?    @default("[]")
  extractedSkills String[] @default([])

  // Skill gap results
  matchedSkills  String[] @default([])
  missingSkills  String[] @default([])
  readinessScore Float?   @default(0)

  // AI-generated content
  candidateSummary   String?  @db.Text
  learningResources  Json?    @default("[]")
  interviewQuestions Json?
  preparationRoadmap Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
